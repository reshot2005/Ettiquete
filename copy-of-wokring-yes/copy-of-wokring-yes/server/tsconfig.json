{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "api/**/*.ts", "middleware/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
