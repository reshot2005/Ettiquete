{
  "version": 2,
  "builds": [
    {
      "src": "api/auth/register.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/login.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/auth/me.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/register",
      "dest": "/api/auth/register.ts"
    },
    {
      "src": "/api/auth/login",
      "dest": "/api/auth/login.ts"
    },
    {
      "src": "/api/auth/me",
      "dest": "/api/auth/me.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
